s inside brackets.\n# The split results are mapped and stripped of whitespace.\nitems = hpath.split(/,(?![^\\[]*?\\])/).map(&:strip) \n\n# Initialize storage\nno_brackets = []\nbracket_groups = {} # Dictionary to store groups, key = content inside []\n\n# Changed variable name to lowercase\nbracket_regex = /\\[(.*?)\\]/ \n\nitems.each do |item|\n  # Attempt to match the bracket content\n  match = item.match(bracket_regex)\n\n  if match\n    # 1. Item contains brackets. Extract the content for the key.\n    bracket_content = match[1].strip \n    \n    # 2. OMIT THE BRACKETED PART from the item string for cleaner output.\n    # We replace the bracketed pattern with an empty string and strip any resulting whitespace.\n    clean_item = item.gsub(bracket_regex, '').strip + \" [ ]\"\n    \n    # 3. Add the CLEAN item to the corresponding group.\n    if bracket_groups.key?(bracket_content)\n      bracket_groups[bracket_content] << clean_item\n    else\n      bracket_groups[bracket_content] = [clean_item]\n    end\n  else\n    # 4. Item does not contain brackets.\n    no_brackets << item+\" [ ]\"\n  end\nend\n\n# --- 5. Format and Join the Final Output ---\n\nfinal_output = []\n\n# A. List items without brackets first\nfinal_output << @component_definition.name.upcase + \" [ ]\"\n\nfinal_output << no_brackets[1...].join(\"\\n \")\n\n# B. List items grouped by bracket content\nbracket_groups.each do |content, items_list|\n  # Create a distinct heading for the group\n  final_output << \"\\n*\\n[#{content}]\"\n  # Join the cleaned items\n  final_output << items_list.join(\"\\n\")\nend\n\n# Return the result, joining the separate sections with newlines\nfinal_output.join(\"\\n\")"},{"formula":"custom","x":-0.46875,"y":-0.4166666666666667,"rotation":0,"size":"1","anchor":"start-top","color":"#FF0000","custom_formula":"@component_instance"},{"formula":"custom","x":-0.46875,"y":0,"rotation":0,"size":"0.75","anchor":"start","color":"#000000","custom_formula":"@bbox_thickness+\" \" 